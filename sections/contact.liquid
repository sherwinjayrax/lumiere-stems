{%- liquid
  assign img_position = section.settings.image_position | default: 'object-center'
-%}

{%- comment -%} ══ Capture social icons once, reuse in all 3 breakpoint locations ══ {%- endcomment -%}
{%- capture social_icons -%}
  {%- if section.settings.instagram_url != blank -%}
    <li>
      <a href="{{ section.settings.instagram_url }}" aria-label="Instagram" target="_blank" rel="noopener noreferrer"
         class="block text-gray-900 hover:text-gray-400 transition-colors duration-200">
        <img src="{{ 'instagram.svg' | asset_url }}" width="24" height="24" alt="Instagram icon">
      </a>
    </li>
  {%- endif -%}
  {%- if section.settings.pinterest_url != blank -%}
    <li>
      <a href="{{ section.settings.pinterest_url }}" aria-label="Pinterest" target="_blank" rel="noopener noreferrer"
         class="block text-gray-900 hover:text-gray-400 transition-colors duration-200">
        <img src="{{ 'pinterest.svg' | asset_url }}" width="24" height="24" alt="Pinterest icon">
      </a>
    </li>
  {%- endif -%}
  {%- if section.settings.facebook_url != blank -%}
    <li>
      <a href="{{ section.settings.facebook_url }}" aria-label="Facebook" target="_blank" rel="noopener noreferrer"
         class="block text-gray-900 hover:text-gray-400 transition-colors duration-200">
        <img src="{{ 'facebook.svg' | asset_url }}" width="24" height="24" alt="Facebook icon">
      </a>
    </li>
  {%- endif -%}
  {%- if section.settings.twitter_url != blank -%}
    <li>
      <a href="{{ section.settings.twitter_url }}" aria-label="Twitter / X" target="_blank" rel="noopener noreferrer"
         class="block text-gray-900 hover:text-gray-400 transition-colors duration-200">
        <img src="{{ 'twitter.svg' | asset_url }}" width="24" height="24" alt="Twitter icon">
      </a>
    </li>
  {%- endif -%}
  {%- if section.settings.telegram_url != blank -%}
    <li>
      <a href="{{ section.settings.telegram_url }}" aria-label="Telegram" target="_blank" rel="noopener noreferrer"
         class="block text-gray-900 hover:text-gray-400 transition-colors duration-200">
        <img src="{{ 'telegram.svg' | asset_url }}" width="24" height="24" alt="Telegram icon">
      </a>
    </li>
  {%- endif -%}
{%- endcapture -%}

<section class="bg-white overflow-hidden border-t border-black-primary h-auto lg:h-screen">
  <div class="lg:hidden w-full overflow-hidden" style="aspect-ratio: 16/9;">
    {%- if section.settings.store_image != blank -%}
      <img
        src="{{ section.settings.store_image | image_url: width: 1200 }}"
        alt="{{ section.settings.store_image.alt | escape }}"
        width="{{ section.settings.store_image.width }}"
        height="{{ section.settings.store_image.height }}"
        loading="lazy"
        class="w-full h-full object-cover {{ img_position }}"
      >
    {%- else -%}
      <div class="w-full h-full bg-gray-200 flex items-center justify-center min-h-55">
        <span class="text-gray-400 text-sm">Upload a store image</span>
      </div>
    {%- endif -%}
  </div>

  {%- comment -%} ══ FOLLOW US — mobile & tablet (below image, above contact form) ══ {%- endcomment -%}

  {%- comment -%} Mobile: stacked label + icons {%- endcomment -%}
  <div class="md:hidden p-4 border-y border-black-primary">
    <p class="text-[1.625rem] poppins-medium text-black-primary mb-3">Follow us</p>
    <ul class="flex items-center gap-6" role="list">
      {{ social_icons }}
    </ul>
  </div>

  {%- comment -%} Tablet: 2-col label | icons {%- endcomment -%}
  <div class="hidden md:grid lg:hidden grid-cols-2 divide-x divide-black-primary border-y border-black-primary">
    <div class="px-10 py-4 flex items-center justify-center">
      <p class="text-[2.375rem] poppins-medium text-black-primary">Follow us:</p>
    </div>
    <div class="px-10 py-4 flex items-center justify-center">
      <ul class="flex items-center gap-8" role="list">
        {{ social_icons }}
      </ul>
    </div>
  </div>

  {%- comment -%} ══ MAIN GRID — single col on mobile/tablet, 2-col on desktop ══ {%- endcomment -%}
  <div class="lg:grid lg:grid-cols-2 h-full">
    {%- comment -%} ── LEFT COLUMN: contact form + phone/address ── {%- endcomment -%}
    <div class="flex flex-col border-black-primary border-r">
      {%- comment -%} Contact form {%- endcomment -%}
      <div class="px-4 py-10 md:p-20 h-full">
        <h2 class="text-[2.125rem] md:text-[3.125rem] poppins-semibold text-black-primary mb-6 leading-[120%]">
          {{ section.settings.form_heading | default: 'To Contact Us' }}
        </h2>
        <p class="text-lg text-black-primary mb-4">
          {{ section.settings.form_subtext | default: 'We will call you back' }}
        </p>
        <div class="flex flex-col gap-4 md:flex-row">
          <input
            type="tel"
            name="contact_phone"
            placeholder="{{ section.settings.phone_placeholder | default: '+000 XX XXX XX XX' }}"
            class="w-full md:basis-1/2 poppins-medium border border-[#D2D2D7] text-sm text-black-primary placeholder-[#808080] p-4 outline-none focus:border-black-primary transition-colors duration-200"
            aria-label="Your phone number"
          >
          <button
            type="button"
            class="w-full md:basis-1/2 poppins-medium shrink-0 bg-black-primary text-white text-sm md:text-base tracking-normal uppercase px-6 py-4 hover:opacity-90 transition-colors duration-200 cursor-pointer"
          >
            {{ section.settings.button_label | default: 'Book a Call' }}
          </button>
        </div>
      </div>

      {%- comment -%} Phone + Address bordered grid {%- endcomment -%}
      <div class="flex flex-col md:flex-row h-full">
        {%- comment -%} Header row {%- endcomment -%}
        <div class="flex flex-col basis-full">
          <div class="p-4 md:px-7 md:py-6 border-y md:border-r border-black-primary">
            <h3 class="text-[1.625rem] md:text-[2.375rem] poppins-medium text-start md:text-center">Phone</h3>
          </div>
          <div class="px-4 py-10 md:p-10 md:h-76.5 lg:h-full border-r border-black-primary flex flex-col justify-center md:items-center gap-5">
            {%- if section.settings.phone_1 != blank -%}
              <a
                href="tel:{{ section.settings.phone_1 | remove: ' ' }}"
                class="flex items-center gap-3 hover:opacity-90 transition-colors duration-200"
              >
                {% render 'phone-svg.liquid' %}
                <span class="poppins-semibold text-base text-black-primary">{{ section.settings.phone_1 }}</span>
              </a>
            {%- endif -%}
            {%- if section.settings.phone_2 != blank -%}
              <a
                href="tel:{{ section.settings.phone_2 | remove: ' ' }}"
                class="flex items-center gap-3 hover:opacity-90 transition-colors duration-200"
              >
                {% render 'phone-svg.liquid' %}
                <span class="poppins-semibold text-base text-black-primary">{{ section.settings.phone_2 }}</span>
              </a>
            {%- endif -%}
          </div>
        </div>
        <div class="flex flex-col basis-full">
          <div class="p-4 md:px-7 md:py-6 border-y border-black-primary">
            <h3 class="text-[1.625rem] md:text-[2.375rem] poppins-medium text-start md:text-center">Address</h3>
          </div>
          <div class="px-4 py-10 md:p-10 md:h-76.5 lg:h-full flex flex-col justify-center gap-4 md:items-center">
            {%- if section.settings.opening_hours != blank -%}
              <p class="text-xs md:text-sm uppercase poppins-medium text-black-primary">
                {{ section.settings.opening_hours }}
              </p>
            {%- endif -%}
            {%- if section.settings.address != blank -%}
              <div class="flex items-start gap-2">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M12 16.475C13.65 15.1417 14.896 13.8583 15.738 12.625C16.5793 11.3917 17 10.2333 17 9.15C17 8.21667 16.8293 7.42067 16.488 6.762C16.146 6.104 15.725 5.57067 15.225 5.162C14.725 4.754 14.1833 4.45833 13.6 4.275C13.0167 4.09167 12.4833 4 12 4C11.5167 4 10.9833 4.09167 10.4 4.275C9.81667 4.45833 9.275 4.754 8.775 5.162C8.275 5.57067 7.85433 6.104 7.513 6.762C7.171 7.42067 7 8.21667 7 9.15C7 10.2333 7.42067 11.3917 8.262 12.625C9.104 13.8583 10.35 15.1417 12 16.475ZM12 19C9.65 17.2667 7.89567 15.5833 6.737 13.95C5.579 12.3167 5 10.7167 5 9.15C5 7.96667 5.21267 6.929 5.638 6.037C6.06267 5.14567 6.60833 4.4 7.275 3.8C7.94167 3.2 8.69167 2.75 9.525 2.45C10.3583 2.15 11.1833 2 12 2C12.8167 2 13.6417 2.15 14.475 2.45C15.3083 2.75 16.0583 3.2 16.725 3.8C17.3917 4.4 17.9377 5.14567 18.363 6.037C18.7877 6.929 19 7.96667 19 9.15C19 10.7167 18.4207 12.3167 17.262 13.95C16.104 15.5833 14.35 17.2667 12 19ZM12 11C12.55 11 13.021 10.804 13.413 10.412C13.8043 10.0207 14 9.55 14 9C14 8.45 13.8043 7.979 13.413 7.587C13.021 7.19567 12.55 7 12 7C11.45 7 10.9793 7.19567 10.588 7.587C10.196 7.979 10 8.45 10 9C10 9.55 10.196 10.0207 10.588 10.412C10.9793 10.804 11.45 11 12 11ZM5 22V20H19V22H5Z" fill="black"/>
                </svg>

                <span class="poppins-semibold text-sm md:text-base text-black-primary">
                  {{- section.settings.address -}}
                </span>
              </div>
            {%- endif -%}
          </div>
        </div>
      </div>
    </div>

    {%- comment -%} ── RIGHT COLUMN: image, desktop only ── {%- endcomment -%}
    <div class="flex flex-col">
      <div class="hidden lg:flex flex-col h-full">
        {%- if section.settings.store_image != blank -%}
          <img
            src="{{ section.settings.store_image | image_url: width: 1400 }}"
            alt="{{ section.settings.store_image.alt | escape }}"
            width="{{ section.settings.store_image.width }}"
            height="{{ section.settings.store_image.height }}"
            loading="lazy"
            class=" w-full h-full object-cover {{ img_position }}"
          >
        {%- else -%}
          <div class=" bg-gray-200 flex items-center justify-center h-full">
            <span class="text-gray-400 text-sm">Upload a store image</span>
          </div>
        {%- endif -%}
      </div>
      <div class="hidden lg:grid grid-cols-2 border-t border-black-primary">
        <div class="px-10 py-4 flex items-center justify-center border-r border-black-primary">
          <p class="text-[2.375rem] poppins-medium text-black-primary">Follow us</p>
        </div>
        <div class="px-10 py-4 flex items-center justify-center">
          <ul class="flex items-center gap-8" role="list">
            {{ social_icons }}
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Contact",
  "limit": 1,
  "settings": [
    {
      "type": "header",
      "content": "Store Image"
    },
    {
      "type": "image_picker",
      "id": "store_image",
      "label": "Store Image"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image Position",
      "options": [
        { "value": "object-center", "label": "Center" },
        { "value": "object-top", "label": "Top" },
        { "value": "object-bottom", "label": "Bottom" },
        { "value": "object-left", "label": "Left" },
        { "value": "object-right", "label": "Right" },
        { "value": "object-left-top", "label": "Left Top" },
        { "value": "object-right-top", "label": "Right Top" },
        { "value": "object-left-bottom", "label": "Left Bottom" },
        { "value": "object-right-bottom", "label": "Right Bottom" }
      ],
      "default": "object-center"
    },
    {
      "type": "header",
      "content": "Contact Form"
    },
    {
      "type": "text",
      "id": "form_heading",
      "label": "Heading",
      "default": "To Contact Us"
    },
    {
      "type": "text",
      "id": "form_subtext",
      "label": "Subtext",
      "default": "We will call you back"
    },
    {
      "type": "text",
      "id": "phone_placeholder",
      "label": "Phone Input Placeholder",
      "default": "+000 XX XXX XX XX"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Book a Call"
    },
    {
      "type": "header",
      "content": "Phone Numbers"
    },
    {
      "type": "text",
      "id": "phone_1",
      "label": "Phone Number 1",
      "default": "+000000000000"
    },
    {
      "type": "text",
      "id": "phone_2",
      "label": "Phone Number 2",
      "default": "+000000000000"
    },
    {
      "type": "header",
      "content": "Address"
    },
    {
      "type": "text",
      "id": "opening_hours",
      "label": "Opening Hours",
      "default": "Opening Hours: 8 to 11 P.M."
    },
    {
      "type": "text",
      "id": "address",
      "label": "Address",
      "default": "15/4 Xyz."
    },
    {
      "type": "header",
      "content": "Social Media"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "pinterest_url",
      "label": "Pinterest URL"
    },
    {
      "type": "url",
      "id": "facebook_url",
      "label": "Facebook URL"
    },
    {
      "type": "url",
      "id": "twitter_url",
      "label": "Twitter / X URL"
    },
    {
      "type": "url",
      "id": "telegram_url",
      "label": "Telegram URL"
    }
  ],
  "presets": [
    {
      "name": "Contact"
    }
  ]
}
{% endschema %}
