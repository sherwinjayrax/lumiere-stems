<script src="{{ 'reviews.js' | asset_url }}" defer></script>

<section
  class="reviews-section h-screen w-full bg-white py-20 text-center border-t border-black-primary flex flex-col items-center justify-center"
  data-reviews-section
>
  <p class="poppins-medium xs:text-xs md:text-sm text-black-primary uppercase mb-2">
    {{ section.settings.subtitle | default: 'Reviews' }}
  </p>
  <h2 class="poppins-semibold xs:text-[2.125rem] md:text-[3.125rem] text-black-primary mb-4 leading-[120%]">
    {{ section.settings.heading | default: 'Our Clients say' }}
  </h2>

  {%- comment -%} ── Carousel ── {%- endcomment -%}
  <div class="relative flex items-center justify-center w-full gap-6">
    {%- comment -%} Prev arrow — desktop only {%- endcomment -%}
    <button
      class="reviews-prev hidden lg:flex shrink-0 w-12 items-center justify-center text-black-primary transition-colors duration-200 z-10 self-center cursor-pointer"
      aria-label="Previous review"
    >
      <svg
        width="10"
        height="18"
        viewBox="0 0 10 18"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <polyline points="9 1 1 9 9 17"/>
      </svg>
    </button>

    {%- comment -%} Clipping wrapper — THIS is what prevents bleed-through {%- endcomment -%}
    <div class="reviews-viewport w-full max-w-3xl overflow-hidden">
      <div
        class="reviews-track flex"
        style="will-change: transform; transition: transform 0.45s cubic-bezier(0.4,0,0.2,1);"
      >
        {%- for block in section.blocks -%}
          {%- if block.type == 'review' -%}
            <div class="review-slide w-full shrink-0 px-6 md:px-10" {{ block.shopify_attributes }}>
              <blockquote class="mb-4">
                <p class="text-[1.375rem] md:text-3xl poppins-semibold font-extrabold text-black-primary leading-[120%]">
                  <span class="inline-block text-3xl md:text-4xl align-top leading-none">&ldquo;</span>
                  {{- block.settings.review_text -}}
                  <span class="inline-block text-3xl md:text-4xl align-bottom leading-none">&rdquo;</span>
                </p>
              </blockquote>
              {%- if block.settings.reviewer_name != blank -%}
                <p class="text-base poppins-medium text-black-primary mt-4">
                  &ndash; {{ block.settings.reviewer_name }}
                </p>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>

    {%- comment -%} Next arrow — desktop only {%- endcomment -%}
    <button
      class="reviews-next hidden lg:flex shrink-0 w-12 items-center justify-center text-black-primary transition-colors duration-200 z-10 self-center cursor-pointer"
      aria-label="Next review"
    >
      <svg
        width="10"
        height="18"
        viewBox="0 0 10 18"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <polyline points="1 1 9 9 1 17"/>
      </svg>
    </button>
  </div>

  {%- comment -%} ── Dot indicators ── {%- endcomment -%}
  {%- assign review_count = 0 -%}
  {%- for block in section.blocks -%}
    {%- if block.type == 'review' -%}{%- assign review_count = review_count | plus: 1 -%}{%- endif -%}
  {%- endfor -%}

  {%- if review_count > 1 -%}
    <div class="reviews-dots flex items-center justify-center gap-2 mt-8 mb-10">
      {%- for i in (1..review_count) -%}
        <button
          class="review-dot w-2 h-2 rounded-full transition-colors duration-300 {% if forloop.first %}bg-gray-900{% else %}bg-gray-300{% endif %}"
          data-index="{{ forloop.index0 }}"
          aria-label="Go to review {{ forloop.index }}"
        ></button>
      {%- endfor -%}
    </div>
  {%- else -%}
    <div class="mt-10 mb-10"></div>
  {%- endif -%}

  {%- comment -%} ── CTA Button ── {%- endcomment -%}
  {%- if section.settings.button_label != blank and section.settings.button_url != blank -%}
    <a
      href="{{ section.settings.button_url }}"
      class="inline-block poppins-medium border border-black-primary text-black-primary  xs:text-sm md:text-base uppercase px-6 py-4 hover:bg-black-primary hover:text-white transition-colors duration-200 mt-16 xs:self-stretch md:self-auto xs:mx-7 md:mx-0"
    >
      {{ section.settings.button_label }}
    </a>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Reviews",
  "limit": 1,
  "settings": [
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Reviews"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Clients say"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Read Reviews"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button URL"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "textarea",
          "id": "review_text",
          "label": "Review Text",
          "default": "Ordered flowers online and they were the best flowers! Impressed everyone around. Highly recommend this flower shop!"
        },
        {
          "type": "text",
          "id": "reviewer_name",
          "label": "Reviewer Name",
          "default": "Ronald Richards"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Reviews",
      "blocks": [
        {
          "type": "review",
          "settings": {
            "review_text": "Ordered flowers online and they were the best flowers! Impressed everyone around. Highly recommend this flower shop!",
            "reviewer_name": "Ronald Richards"
          }
        },
        {
          "type": "review",
          "settings": {
            "review_text": "Absolutely stunning arrangement! The flowers were fresh and beautifully arranged. Will definitely be ordering again for every occasion.",
            "reviewer_name": "Emily Carter"
          }
        }
      ]
    }
  ]
}
{% endschema %}
