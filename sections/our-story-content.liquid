<section class="bg-white flex flex-col">
  {%- comment -%} ══ TOP INTRO — eyebrow + heading + richtext ══ {%- endcomment -%}
  <div class="w-full px-4 py-10 md:p-20 text-center border-y border-black-primary">
    <div class="max-w-xl mx-auto">
      {%- if section.settings.eyebrow != blank -%}
        <p class="text-xs md:text-sm poppins-medium uppercase text-black-primary mb-6">
          {{ section.settings.eyebrow }}
        </p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="text-[1.625rem] md:text-[2.375rem] poppins-medium text-black-primary leading-[120%] mb-4">
          {{ section.settings.heading }}
        </h2>
      {%- endif -%}

      {%- if section.settings.intro_text != blank -%}
        <div class="text-base text-black-secondary leading-[140%] story-richtext">
          {{ section.settings.intro_text }}
        </div>
      {%- endif -%}
    </div>
  </div>

  {%- comment -%} ══ REUSABLE IMAGE + TEXT BLOCKS ══ {%- endcomment -%}
  {%- for block in section.blocks -%}
    {%- if block.type == 'story_block' -%}
      {%- liquid
        assign placement = block.settings.image_placement | default: 'left'
        assign img_pos = block.settings.image_position | default: 'object-center'
        assign is_even = forloop.index | modulo: 2
      -%}

      <div
        class="flex flex-col lg:flex-row h-auto lg:h-screen lg:divide-x divide-black-primary {% if is_even == 0 %}border-y border-black-primary{% endif %}"
        {{ block.shopify_attributes }}
      >
        {%- comment -%} Image half {%- endcomment -%}
        <div
          class="w-full flex min-h-75 md:min-h-125 border-b border-black-primary lg:border-b-0 lg:min-h-auto h-1/2 lg:h-full lg:w-1/2 overflow-hidden {% if placement == 'right' %}lg:order-2{% else %}lg:order-1{% endif %}"
        >
          {%- if block.settings.image != blank -%}
            <img
              src="{{ block.settings.image | image_url: width: 1200 }}"
              alt="{{ block.settings.image.alt | escape | default: block.settings.block_heading }}"
              width="{{ block.settings.image.width }}"
              height="{{ block.settings.image.height }}"
              loading="lazy"
              class="w-full object-cover {{ img_pos }}"
            >
          {%- else -%}
            <div class="w-full bg-gray-100 flex items-center justify-center">
              <span class="text-gray-400 text-sm">Upload an image</span>
            </div>
          {%- endif -%}
        </div>

        {%- comment -%} Text half {%- endcomment -%}
        <div class="w-full h-1/2 lg:h-full lg:w-1/2 flex items-center lg:items-start px-4 py-10 md:p-20 {% if placement == 'right' %}lg:order-1 border-r border-black-primary{% else %}lg:order-2{% endif %}">
          <div class="max-w-md">
            {%- if block.settings.block_heading != blank -%}
              <h3 class="text-[1.625rem] md:text-[2.375rem] poppins-medium text-black-primary leading-[120%] mb-4">
                {{ block.settings.block_heading }}
              </h3>
            {%- endif -%}
            {%- if block.settings.block_text != blank -%}
              <div class="text-base text-black-secondary leading-[140%] story-richtext">
                {{ block.settings.block_text }}
              </div>
            {%- endif -%}
          </div>
        </div>
      </div>
    {%- endif -%}
  {%- endfor -%}
</section>

<style>
  .story-richtext p {
    margin-bottom: 0.75rem;
  }
  .story-richtext p:last-child {
    margin-bottom: 0;
  }
  .story-richtext strong {
    font-weight: 700;
    color: #111827;
  }
  .story-richtext a {
    text-decoration: underline;
  }
  .story-richtext ul {
    list-style: disc;
    padding-left: 1.25rem;
    margin-bottom: 0.75rem;
  }
  .story-richtext ol {
    list-style: decimal;
    padding-left: 1.25rem;
    margin-bottom: 0.75rem;
  }
</style>

{% schema %}
{
  "name": "Our Story Content",
  "limit": 1,
  "settings": [
    {
      "type": "header",
      "content": "Intro Block"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Label",
      "default": "Our Story"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Founder's Passion"
    },
    {
      "type": "richtext",
      "id": "intro_text",
      "label": "Intro Description",
      "default": "<p>Lumière Stems was founded in 2010 by John Doe with the goal of bringing unique and exquisite bouquets to the people of London. John has always had a passion for flowers and design, and his vision was to create a local floral studio that would specialize in the creation and delivery of fresh, beautiful, and distinctive bouquets.</p>"
    }
  ],
  "blocks": [
    {
      "type": "story_block",
      "name": "Story Block",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Block Image"
        },
        {
          "type": "select",
          "id": "image_position",
          "label": "Image Focal Point",
          "options": [
            { "value": "object-center", "label": "Center" },
            { "value": "object-top", "label": "Top" },
            { "value": "object-bottom", "label": "Bottom" },
            { "value": "object-left", "label": "Left" },
            { "value": "object-right", "label": "Right" },
            { "value": "object-left-top", "label": "Left Top" },
            { "value": "object-right-top", "label": "Right Top" },
            { "value": "object-left-bottom", "label": "Left Bottom" },
            { "value": "object-right-bottom", "label": "Right Bottom" }
          ],
          "default": "object-center"
        },
        {
          "type": "select",
          "id": "image_placement",
          "label": "Image Placement",
          "options": [
            { "value": "left", "label": "Left" },
            { "value": "right", "label": "Right" }
          ],
          "default": "left"
        },
        {
          "type": "text",
          "id": "block_heading",
          "label": "Heading",
          "default": "Expertly Crafted Bouquets"
        },
        {
          "type": "richtext",
          "id": "block_text",
          "label": "Description",
          "default": "<p>At Lumière Stems, we take pride in our team of talented and experienced florists who carefully select each bloom, ensuring that only the freshest and most stunning flowers make it into our bouquets. We work directly with farms to source the highest quality flowers, and our skilled florists expertly craft each bouquet to perfection.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Our Story Content",
      "category": "About",
      "blocks": [
        {
          "type": "story_block",
          "settings": {
            "block_heading": "Expertly Crafted Bouquets",
            "image_placement": "left",
            "image_position": "object-center"
          }
        }
      ]
    }
  ]
}
{% endschema %}
