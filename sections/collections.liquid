{% comment %}
  This template renders the /collections page listing all collections.
  https://shopify.dev/docs/storefronts/themes/architecture/templates/list-collections
{% endcomment %}

<section class="bg-white h-auto md:h-screen flex flex-col">
  {%- comment -%} ══ GRID ══ {%- endcomment -%}
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 divide-x divide-black-primary h-full">
    {%- for collection in collections -%}
      {%- comment -%} Skip empty collections if needed {%- endcomment -%}
      <a
        href="{{ collection.url }}"
        class="
          group relative overflow-hidden block
          border-b border-black-primary lg:border-b-0
          h-[60vh] md:h-auto lg:h-full last:border-0 last:border-r
        "
      >
        {%- comment -%} Collection image {%- endcomment -%}
        {%- if collection.featured_image != blank -%}
          <img
            src="{{ collection.featured_image | image_url: width: 1000 }}"
            alt="{{ collection.featured_image.alt | escape | default: collection.title }}"
            width="{{ collection.featured_image.width }}"
            height="{{ collection.featured_image.height }}"
            loading="lazy"
            class="
              absolute inset-0 w-full h-full object-cover object-center
              group-hover:scale-105 transition-transform duration-500 ease-in-out
            "
          >
        {%- else -%}
          <div class="absolute inset-0 bg-gray-200"></div>
        {%- endif -%}

        {%- comment -%} Dark overlay {%- endcomment -%}
        <div class="absolute inset-0 bg-black/30 group-hover:bg-black/45 transition-colors duration-300"></div>

        {%- comment -%} Collection title — absolute bottom left {%- endcomment -%}
        <div class="absolute bottom-0 left-0 right-0 p-5 md:p-7 lg:p-10">
          <h2 class="text-[2.5rem] lg:text-[2.8rem] poppins-semibold text-white leading-tight">
            {{ collection.title }}
          </h2>
          {%- if collection.description != blank -%}
            <p class="text-xs md:text-sm text-white/80 mt-2 leading-relaxed line-clamp-2">
              {{ collection.description | strip_html }}
            </p>
          {%- endif -%}
        </div>
      </a>

    {%- else -%}
      <div class="col-span-3 flex items-center justify-center py-20">
        <p class="text-sm text-black-secondary">No collections found.</p>
      </div>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Collections List",
  "settings": []
}
{% endschema %}
