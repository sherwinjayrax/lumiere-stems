{%- comment -%} Backdrop {%- endcomment -%}
<div
  id="cart-backdrop"
  class="fixed inset-0 z-50 bg-black/40 opacity-0 pointer-events-none transition-opacity duration-300 backdrop-blur-xs"
  aria-hidden="true"
></div>

{%- comment -%} ══ CART DRAWER PANEL ══ {%- endcomment -%}
<div
  id="cart-drawer"
  role="dialog"
  aria-modal="true"
  aria-label="Shopping Cart"
  class="
    fixed top-0 right-0 z-50 h-full
    w-full md:w-1/2
    bg-white border-l border-black-primary
    flex flex-col
    translate-x-full transition-transform duration-300 ease-in-out
  "
>
  {%- comment -%} ── Header row ── {%- endcomment -%}
  <div class="flex items-center justify-between px-6 py-3 md:px-10 md:py-4 lg:py-6.5 border-b border-black-primary shrink-0 bg-[#F5F5F7]">
    <h2 class="text-base poppins-medium text-black-primary">Shopping Cart</h2>
    <button
      id="cart-drawer-close"
      class="grid place-items-center"
      aria-label="Close cart"
    >
      <img src="{{ 'close-button.svg' | asset_url }}" width="24" height="24" alt="Close button icon">
    </button>
  </div>

  {%- comment -%} ── Scrollable body ── {%- endcomment -%}
  <div class="flex-1 overflow-y-auto flex flex-col bg-[#F5F5F7]" id="cart-drawer-body">
    {%- comment -%} Cart items {%- endcomment -%}
    <div
      id="cart-items"
      class="flex flex-col px-4 py-6 md:p-10 gap-5 border-b border-black-primary overflow-y-auto max-h-1/2"
    >
      {%- for item in cart.items -%}
        <div class="flex gap-4 relative" data-key="{{ item.key }}">
          {%- comment -%} Image {%- endcomment -%}
          <a href="{{ item.url }}" class="shrink-0">
            <div class="w-28 md:w-36 aspect-square border border-black-primary overflow-hidden bg-white">
              {%- if item.image -%}
                <img
                  src="{{ item.image | image_url: width: 300 }}"
                  alt="{{ item.image.alt | escape }}"
                  width="300"
                  height="300"
                  loading="lazy"
                  class="w-full h-full object-cover"
                >
              {%- endif -%}
            </div>
          </a>

          {%- comment -%} Info {%- endcomment -%}
          <div class="flex flex-col justify-center gap-1 flex-1">
            <a
              href="{{ item.url }}"
              class="text-sm poppins-bold text-black-primary hover:opacity-70 transition-opacity duration-200 leading-snug"
            >
              {{ item.product.title }}
            </a>
            {%- unless item.variant.title == 'Default Title' -%}
              <p class="text-xs text-black-secondary">{{ item.variant.title }}</p>
            {%- endunless -%}
            <p class="text-xs text-black-secondary">Quantity ({{ item.quantity }})</p>
            <p class="text-sm poppins-bold text-black-primary mt-1">{{ item.final_line_price | money }}</p>
          </div>

          {%- comment -%} Remove button {%- endcomment -%}
          <button
            class="cart-remove absolute right-5 bottom-6 text-xs text-gray-400 hover:text-black-primary transition-colors duration-200"
            data-key="{{ item.key }}"
            aria-label="Remove {{ item.product.title }}"
          >
            Remove
          </button>
        </div>
      {%- else -%}
        <div class="text-center text-sm md:text-base text-black-primary" id="cart-empty-msg">Your cart is empty</div>
      {%- endfor -%}
    </div>

    {%- comment -%} Subtotal {%- endcomment -%}
    <div
      class="flex items-center justify-between px-4 py-6 md:p-10 border-b border-black-primary shrink-0"
      id="cart-subtotal-row"
    >
      <span class="text-lg poppins-medium text-black-primary">Subtotal</span>
      <span class="text-lg poppins-medium text-black-primary" id="cart-subtotal">{{ cart.total_price | money }}</span>
    </div>

    {%- comment -%} Gift message textarea {%- endcomment -%}
    <div class="flex-1 border-b border-black-primary min-h-35">
      <textarea
        id="cart-gift-message"
        name="note"
        placeholder="Gift Message"
        class="w-full h-full min-h-35 bg-transparent px-4 py-6 md:p-10 text-base text-black-primary placeholder-[#808080] outline-none resize-none"
        aria-label="Gift message"
      >{{ cart.note }}</textarea>
    </div>
  </div>

  {%- comment -%} ── Checkout button — sticky bottom ── {%- endcomment -%}
  <div class="shrink-0">
    <a
      href="{{ routes.checkout_url }}"
      id="cart-checkout-btn"
      class="flex items-center justify-center w-full bg-black-primary text-white text-sm md:text-base poppins-medium tracking-normal uppercase px-6 py-4"
    >
      Check out
    </a>
  </div>
</div>

<script>
  (function () {
    const drawer = document.getElementById('cart-drawer');
    const backdrop = document.getElementById('cart-backdrop');
    const closeBtn = document.getElementById('cart-drawer-close');
    const cartTriggers = document.querySelectorAll('[data-cart-trigger]');

    // ── Open / Close ──
    function openCart() {
      drawer.classList.remove('translate-x-full');
      backdrop.classList.remove('opacity-0', 'pointer-events-none');
      backdrop.classList.add('opacity-100', 'pointer-events-auto');
      document.body.style.overflow = 'hidden';
      closeBtn.focus();
    }

    function closeCart() {
      drawer.classList.add('translate-x-full');
      backdrop.classList.remove('opacity-100', 'pointer-events-auto');
      backdrop.classList.add('opacity-0', 'pointer-events-none');
      document.body.style.overflow = '';
    }

    if (closeBtn) closeBtn.addEventListener('click', closeCart);
    if (backdrop) backdrop.addEventListener('click', closeCart);
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeCart();
    });

    cartTriggers.forEach((btn) =>
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        openCart();
      })
    );

    // ── Remove item ──
    document.addEventListener('click', function (e) {
      const btn = e.target.closest('.cart-remove');
      if (!btn) return;
      const key = btn.dataset.key;
      fetch('/cart/change.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: key, quantity: 0 }),
      })
        .then((r) => r.json())
        .then((cart) => refreshCart(cart));
    });

    // ── Save gift note on blur ──
    const noteField = document.getElementById('cart-gift-message');
    if (noteField) {
      noteField.addEventListener('blur', function () {
        fetch('/cart/update.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ note: this.value }),
        });
      });
    }

    // ── Refresh cart HTML after changes ──
    function refreshCart(cart) {
      const itemsContainer = document.getElementById('cart-items');
      const subtotalEl = document.getElementById('cart-subtotal');
      const checkoutBtn = document.getElementById('cart-checkout-btn');
      const cartBadges = document.querySelectorAll('[data-cart-count]');

      // Update count badges in header
      cartBadges.forEach((el) => {
        el.textContent = cart.item_count;
        el.style.display = cart.item_count === 0 ? 'none' : '';
      });

      // Update subtotal
      if (subtotalEl) {
        subtotalEl.textContent = formatMoney(cart.total_price);
      }

      // Re-render items
      if (itemsContainer) {
        if (cart.items.length === 0) {
          itemsContainer.innerHTML =
            '<div class="text-center text-sm md:text-base text-black-primary" id="cart-empty-msg">Your cart is empty</div>';
        } else {
          itemsContainer.innerHTML = cart.items
            .map(
              (item) => `
          <div class="flex gap-4 px-5 py-6 relative" data-key="${item.key}">
            <a href="${item.url}" class="shrink-0">
              <div class="w-28 md:w-36 aspect-square border border-black-primary overflow-hidden bg-white">
                <img src="${item.featured_image ? item.featured_image.url : ''}" alt="${
                item.title
              }" width="300" height="300" loading="lazy" class="w-full h-full object-cover">
              </div>
            </a>
            <div class="flex flex-col justify-center gap-1 flex-1">
              <a href="${
                item.url
              }" class="text-sm poppins-bold text-black-primary hover:opacity-70 transition-opacity duration-200 leading-snug">${
                item.product_title
              }</a>
              ${
                item.variant_title !== 'Default Title'
                  ? `<p class="text-xs text-black-secondary">${item.variant_title}</p>`
                  : ''
              }
              <p class="text-xs text-black-secondary">Quantity (${item.quantity})</p>
              <p class="text-sm poppins-bold text-black-primary mt-1">${formatMoney(item.final_line_price)}</p>
            </div>
            <button class="cart-remove absolute right-5 bottom-6 text-xs text-gray-400 hover:text-black-primary transition-colors duration-200" data-key="${
              item.key
            }" aria-label="Remove ${item.product_title}">Remove</button>
          </div>
        `
            )
            .join('');
        }
      }
    }

    // Simple money formatter
    function formatMoney(cents) {
      return '$' + (cents / 100).toFixed(2);
    }

    // ── Open cart drawer on "Add to cart" success ──
    // Dispatch a custom event from your product form JS: document.dispatchEvent(new Event('cart:open'))
    document.addEventListener('cart:open', openCart);
  })();
</script>
